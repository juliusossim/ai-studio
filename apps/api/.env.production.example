NODE_ENV="production"
PORT="3000"
DATABASE_URL="postgresql://ripples:<password>@db.example.com:5432/ripples"
WEB_ORIGIN="https://app.ripples.example"
AUTH_JWT_SECRET="replace-with-a-long-random-secret"
AUTH_PASSWORD_PEPPER="replace-with-a-different-long-random-secret"
AUTH_CORS_ORIGINS="https://app.ripples.example"
AUTH_COOKIE_SECURE="true"
AUTH_COOKIE_SAME_SITE="none"
AUTH_ACCESS_TOKEN_TTL_SECONDS="900"
AUTH_REFRESH_TOKEN_TTL_SECONDS="2592000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_STATE_TTL_SECONDS="600"
MEDIA_STORAGE_PROVIDER="s3"
MEDIA_STORAGE_BUCKET="ripples-media-production"
MEDIA_STORAGE_REGION="us-east-1"
MEDIA_STORAGE_ENDPOINT=""
MEDIA_STORAGE_PUBLIC_BASE_URL="https://media.ripples.example"
MEDIA_STORAGE_FORCE_PATH_STYLE="false"
MEDIA_STORAGE_KEY_PREFIX="production"
MEDIA_STORAGE_ACCESS_KEY_ID=""
MEDIA_STORAGE_SECRET_ACCESS_KEY=""
MEDIA_STORAGE_SESSION_TOKEN=""
MEDIA_UPLOAD_URL_TTL_SECONDS="900"
MEDIA_MAX_IMAGE_BYTES="20971520"
MEDIA_MAX_VIDEO_BYTES="209715200"
API_RATE_LIMIT_TTL_MS="60000"
API_RATE_LIMIT_LIMIT="120"
HTTP_JSON_BODY_LIMIT_BYTES="1048576"
HTTP_URLENCODED_BODY_LIMIT_BYTES="1048576"
HTTP_TRUST_PROXY="1"
LOG_LEVEL="info"
RIPPLES_SHUTDOWN_TIMEOUT_MS="10000"
SENTRY_ENABLED="true"
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_ENVIRONMENT="production"
SENTRY_RELEASE="ripples-api@<git-sha-or-release-id>"
SENTRY_SAMPLE_RATE="1.0"
SENTRY_SHUTDOWN_TIMEOUT_MS="2000"
