{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@org/source"],
    "paths": {
      "@org/types": ["shared/types/src/index.ts"],
      "@org/utils": ["shared/utils/src/index.ts"],
      "@org/prompts": ["ai/prompts/src/index.ts"],
      "@org/core": ["ai/core/src/index.ts"],
      "@org/ui": ["shared/ui/src/index.ts"]
    }
  }
}
